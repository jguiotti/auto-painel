# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
apps/*/.next/
apps/*/out/

# turbo
.turbo

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets (keep .env.example if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# local / deploy artifacts
.netlify
*.pem
*.p12
id_rsa
id_rsa.pub
*.keystore

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*~

# Supabase CLI local scratch (when used)
supabase/.branches
supabase/.temp

# logs and caches
*.log
.eslintcache
**/.cache/

# OS
Thumbs.db

# typescript
*.tsbuildinfo
