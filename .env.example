# Copie para .env.local na RAIZ do monorepo e preencha.
# Depois rode: npm run sync:env — copia a raiz .env.local para cada app em apps/*/.
# Os next.config também injetam a raiz via scripts/inject-monorepo-env.cjs.
# Não coloque segredos reais neste arquivo de exemplo.

# --- Supabase hosted (produção/staging remoto) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase local (Docker: npm run supabase:start) — ver packages/shared/docs/SUPABASE_LOCAL.md ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase status -o env → ANON_KEY>
# SUPABASE_SERVICE_ROLE_KEY=<supabase status -o env → SERVICE_ROLE_KEY>

# Segredo compartilhado com a Edge Function provision-dealership-user (header x-provision-key).
# No Supabase, defina o mesmo valor em PROVISION_FUNCTION_SECRET (veja packages/shared/docs/SUPABASE_EDGE_PROVISION.md).
ADMIN_PROVISION_FUNCTION_SECRET=

# Keep-alive Supabase hosted (cron diário). Opcional no Edge platform-health-ping (header x-health-ping-key).
# Ver packages/shared/docs/SUPABASE_HEALTH_PING.md e npm run supabase:ping
# PLATFORM_HEALTH_PING_SECRET=

# --- Supabase deploy automatizado (ver packages/shared/docs/SUPABASE_DEPLOY.md) ---
# SUPABASE_PROJECT_REF=wcgevmvystdhqpzwuyig
# SUPABASE_DB_PASSWORD=
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_DB_PUSH_INCLUDE_ALL=true

# Ping keep-alive no projeto hospedado (npm run supabase:ping:remote) — chave do Dashboard remoto
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=

# URL base do painel da concessionária (ex: http://localhost:3002 ou https://painel.loja.pt).
# Usado pelo admin-master ao enviar e-mail de recuperação de senha quando se liga uma conta Auth já existente.
# Tem de coincidir com um URL em Authentication → URL Configuration → Redirect URLs no Supabase.
NEXT_PUBLIC_DEALERSHIP_AUTH_REDIRECT_ORIGIN=

# Opcional — duplicado do URL acima se só precisar de um nome; preferir NEXT_PUBLIC_DEALERSHIP_AUTH_REDIRECT_ORIGIN.
# NEXT_PUBLIC_DEALERSHIP_PANEL_URL=

# Portas HTTP locais (só documentação / admin-master pré-visualização dev). Defaults: painel 3002, vitrine 3003.
# NEXT_PUBLIC_DEALERSHIP_PANEL_DEV_PORT=3002
# NEXT_PUBLIC_CUSTOMER_SITE_DEV_PORT=3003

# Domínio raiz da plataforma (ex.: autopainel.com.br). Produção típica: https://{slug}.autopainel.com.br para painel/vitrine no mesmo wildcard.
# Local multi-loja por subdomínio: NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=localhost → http://SEU_SLUG.localhost:3002 (RFC 6761).
NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=

# Opcional — URL pública do site institucional da AutoPainel (rodapé em /erro/concessionaria, vitrine + painel). Se vazio, o link não é exibido.
# NEXT_PUBLIC_AUTOPAINEL_SITE_URL=https://www.autopainel.com.br

# Opcional — sobrepõe o URL gerado por slug + domínio raiz (marcadores {protocol}, {slug}, {root}).
# NEXT_PUBLIC_DEALERSHIP_PANEL_URL_TEMPLATE=
# NEXT_PUBLIC_CUSTOMER_SITE_URL_TEMPLATE=
# NEXT_PUBLIC_PLATFORM_URL_USE_HTTP=

# Painel: só desenvolvimento — bootstrap do cookie tenant por GET /painel/acesso/:slug. Mantém-se false/em branco em produção (sem página pública de slug).
# NEXT_PUBLIC_ENABLE_DEALERSHIP_PANEL_SLUG_BOOTSTRAP=

# Painel dealership-panel: permite reaproveitar o cookie de tenant quando o Browser acede pelo IP LAN (sem subdomínio).
NEXT_PUBLIC_ALLOW_LAN_HOST_TENANT_COOKIE=

# Opcional / legado na vitrine (customer-site): força slug em localhost nu. Preferir sempre subdomínio ou migrações equivalentes para o storefront.
DEVELOPMENT_TENANT_SLUG=
NEXT_PUBLIC_DEVELOPMENT_TENANT_SLUG=

# Playwright E2E (`npm run test:e2e`): slug existente; vitrine só passa se dealerships.status = active (senão skipped).
# E2E_DEALERSHIP_SLUG=
# E2E_STRICT_STOREFRONT_ACTIVE=
# Configure URLs/credenciais oficiais de cada provedor.
OLX_OAUTH_AUTHORIZATION_URL=
OLX_OAUTH_TOKEN_URL=
OLX_OAUTH_CLIENT_ID=
OLX_OAUTH_CLIENT_SECRET=
OLX_OAUTH_SCOPE=
OLX_OAUTH_REDIRECT_URI=

WEBMOTORS_OAUTH_AUTHORIZATION_URL=
WEBMOTORS_OAUTH_TOKEN_URL=
WEBMOTORS_OAUTH_CLIENT_ID=
WEBMOTORS_OAUTH_CLIENT_SECRET=
WEBMOTORS_OAUTH_SCOPE=
WEBMOTORS_OAUTH_REDIRECT_URI=

# Chave de criptografia simétrica usada nas Edge Functions para cifrar tokens OAuth2.
CLASSIFIEDS_TOKENS_CRYPTO_SECRET=

# OAuth Meta (Instagram Business / Facebook Pages)
# Em produção: preferir credenciais guardadas por loja no painel (Integrações).
# Fallbacks abaixo servem para desenvolvimento local quando não há linha em dealership_meta_oauth_apps.
# META_PLATFORM_APP_ONLY=true — Connect simplificado (app única AutoPainel; oculta App ID/Secret no painel).
# META_PLATFORM_APP_ONLY=true
META_APP_CLIENT_ID=
META_APP_CLIENT_SECRET=
META_OAUTH_REDIRECT_URI=
# Opcional — versão do Graph nas URLs OAuth e callbacks (dialog + graph).
META_GRAPH_API_VERSION=
# Lista separada por vírgulas — omissão usa escopos padrão de publicação/page/IG Business.
META_OAUTH_SCOPES=
# Mesmo algoritmo AES-GCM que classificados; use valor distinto por produto quando possível.
META_TOKENS_CRYPTO_SECRET=

# Workers Epic 2 — classificados (publish/delist assíncrono)
# CLASSIFIEDS_SYNC_DRY_RUN=true — simula publicação quando APIs reais não estão configuradas
# CLASSIFIEDS_SYNC_DRY_RUN=true
# OLX_LISTINGS_API_URL=https://api.olx.example/listings
# WEBMOTORS_LISTINGS_API_URL=https://api.webmotors.example/listings
# CLASSIFIEDS_SYNC_WORKER_SECRET=

# Workers Epic 2 — Meta (publicação assíncrona)
# SOCIAL_PUBLISH_DRY_RUN=true — padrão seguro até homologação Meta (omitir ou false para Graph API real)
# SOCIAL_PUBLISH_DRY_RUN=true
# SOCIAL_PUBLISH_WORKER_SECRET=

# Opcional dealership-panel Next: apenas se META_OAUTH_REDIRECT_URI não existir usa:
# NEXT_PUBLIC_SUPABASE_URL + "/functions/v1/meta-oauth-callback"
