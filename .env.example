# Copie para .env.local na RAIZ do monorepo e preencha.
# Depois rode: npm run sync:env — copia a raiz .env.local para cada app em apps/*/.
# Os next.config também injetam a raiz via scripts/inject-monorepo-env.cjs.
# Não coloque segredos reais neste arquivo de exemplo.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Segredo compartilhado com a Edge Function provision-dealership-user (header x-provision-key).
# No Supabase, defina o mesmo valor em PROVISION_FUNCTION_SECRET (veja packages/shared/docs/SUPABASE_EDGE_PROVISION.md).
ADMIN_PROVISION_FUNCTION_SECRET=

# Domínio raiz da plataforma (ex: autopainel.com). Usado para mapear subdomínio -> slug da concessionária.
NEXT_PUBLIC_PLATFORM_ROOT_DOMAIN=

# Apenas desenvolvimento: em localhost, força o tenant pelo slug (deve existir em public.dealerships).
DEVELOPMENT_TENANT_SLUG=

# OAuth2 classificados (OLX / WebMotors)
# Configure URLs/credenciais oficiais de cada provedor.
OLX_OAUTH_AUTHORIZATION_URL=
OLX_OAUTH_TOKEN_URL=
OLX_OAUTH_CLIENT_ID=
OLX_OAUTH_CLIENT_SECRET=
OLX_OAUTH_SCOPE=
OLX_OAUTH_REDIRECT_URI=

WEBMOTORS_OAUTH_AUTHORIZATION_URL=
WEBMOTORS_OAUTH_TOKEN_URL=
WEBMOTORS_OAUTH_CLIENT_ID=
WEBMOTORS_OAUTH_CLIENT_SECRET=
WEBMOTORS_OAUTH_SCOPE=
WEBMOTORS_OAUTH_REDIRECT_URI=

# Chave de criptografia simétrica usada nas Edge Functions para cifrar tokens OAuth2.
CLASSIFIEDS_TOKENS_CRYPTO_SECRET=

# OAuth Meta (Instagram Business / Facebook Pages) — app em developers.facebook.com
META_APP_CLIENT_ID=
META_APP_CLIENT_SECRET=
META_OAUTH_REDIRECT_URI=
# Opcional — versão do Graph nas URLs OAuth e callbacks (dialog + graph).
META_GRAPH_API_VERSION=
# Lista separada por vírgulas — omissão usa escopos padrão de publicação/page/IG Business.
META_OAUTH_SCOPES=
# Mesmo algoritmo AES-GCM que classificados; use valor distinto por produto quando possível.
META_TOKENS_CRYPTO_SECRET=

# Opcional dealership-panel Next: apenas se META_OAUTH_REDIRECT_URI não existir usa:
# NEXT_PUBLIC_SUPABASE_URL + "/functions/v1/meta-oauth-callback"
