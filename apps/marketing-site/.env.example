# Marketing site (apps/marketing-site) — copie para .env.local na raiz do monorepo
# e rode: npm run sync:env
#
# Guia deploy: packages/shared/docs/VERCEL_DEPLOY.md
# Trial onboarding uploads: packages/shared/docs/SUPABASE_DEPLOY.md (campanha jun/2026)

# --- Público (browser) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Servidor (NUNCA prefixar NEXT_PUBLIC_) ---
# Obrigatório em produção para upload de logos/hero no formulário /adesao-trial
# (bucket dealership-onboarding-intakes via service role).
SUPABASE_SERVICE_ROLE_KEY=

# E-mails transacionais TRIAL-01/02 (Resend API) — ver packages/shared/docs/EMAIL_COMMUNICATION_REGUA.md §8
RESEND_API_KEY=
# Opcional — default: AutoPainel <noreply@autopainel.com.br>
# AUTOPAINEL_TRANSACTIONAL_FROM_EMAIL=

# GTM — ver packages/shared/docs/GTM.md
NEXT_PUBLIC_GTM_ID=GTM-MV99ZXW9

# URL canônica do site (SEO, sitemap, Open Graph)
# NEXT_PUBLIC_AUTOPAINEL_SITE_URL=https://autopainel.com.br
