{
  "name": "auto-painel",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "turbo run dev --filter=@autopainel/marketing-site --filter=@autopainel/admin-master --filter=@autopainel/dealership-panel --filter=@autopainel/customer-site",
    "dev:lite": "turbo run dev --concurrency=2 --filter=@autopainel/admin-master --filter=@autopainel/dealership-panel --filter=@autopainel/customer-site",
    "dev:warm": "node scripts/warm-dev-apps.mjs",
    "dev:warm:lite": "node scripts/warm-dev-apps.mjs --lite",
    "dev:marketing-site": "turbo run dev --filter=@autopainel/marketing-site",
    "dev:admin-master": "turbo run dev --filter=@autopainel/admin-master",
    "dev:dealership-panel": "turbo run dev --filter=@autopainel/dealership-panel",
    "dev:customer-site": "turbo run dev --filter=@autopainel/customer-site",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "sync:env": "node scripts/sync-env-local.mjs",
    "seed:demo-users": "NODE_PATH=./packages/shared/node_modules node scripts/seed-demo-dealership-users.mjs",
    "seed:admin-user": "NODE_PATH=./packages/shared/node_modules node scripts/seed-admin-super-user.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "supabase:ping": "node scripts/ping-supabase-health.mjs",
    "supabase:ping:remote": "node scripts/ping-supabase-health.mjs --remote",
    "supabase:migrations:status": "node scripts/supabase-migration-status.mjs",
    "supabase:deploy": "node scripts/supabase-deploy.mjs",
    "github:secrets:workers": "node scripts/configure-github-worker-secrets.mjs",
    "github:secrets:workers:manual": "node scripts/configure-github-worker-secrets.mjs --manual",
    "integration:secrets:configure": "node scripts/configure-integration-secrets.mjs",
    "integration:secrets:configure:manual": "node scripts/configure-integration-secrets.mjs --manual",
    "classifieds:oauth:dev:configure": "node scripts/configure-classifieds-oauth-dev.mjs",
    "classifieds:oauth:platform:configure": "node scripts/configure-classifieds-oauth-platform.mjs",
    "classifieds:oauth:secrets:configure": "node scripts/configure-classifieds-oauth-secrets.mjs",
    "vercel:link:all": "node scripts/vercel-link-all.mjs",
    "env:check-tracked": "node scripts/check-env-not-tracked.mjs",
    "git:untrack-env": "bash scripts/untrack-env-from-git.sh",
    "git:purge-secrets": "bash scripts/git-purge-secrets-from-history.sh",
    "git:repair-index": "bash scripts/git-repair-index.sh",
    "clean:caches": "bash scripts/clean-caches.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
